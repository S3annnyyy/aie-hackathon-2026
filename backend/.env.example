APP_NAME=interior-generation
APP_ENV=dev
LOG_LEVEL=INFO
STORAGE_ROOT=storage
UPLOAD_SUBDIR=uploads
PROJECTS_SUBDIR=projects
SUPABASE_DB_URL=
SUPABASE_STORAGE_BASE_URL=
SUPABASE_STORAGE_BUCKET=interior-assets
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PAGE_LAYOUT_MODEL=gpt-5.4-mini

# Interior designer chat — pick one provider for the agent + vision.
# Options: gemini | openai | anthropic
CHAT_LLM_PROVIDER=gemini
CHAT_OPENAI_MODEL=
CHAT_MAX_TOOL_ITERATIONS=8

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

BLENDER_EXECUTABLE=blender
BLENDER_SCRIPT_PATH=scripts/blender_generate_model.py
BLENDER_TIMEOUT_SECONDS=180
BLENDER_EXPORT_DEBUG_MARKERS=false

# Optional: connect chat tools to a live Blender with the blender-mcp addon running.
# Leave BLENDER_MCP_ENABLED=false for a lighter demo that only mutates the schema.
BLENDER_MCP_ENABLED=false
BLENDER_MCP_HOST=127.0.0.1
BLENDER_MCP_PORT=9876
BLENDER_MCP_TIMEOUT_SECONDS=30

PAGE_RENDER_DPI=400
