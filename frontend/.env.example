VITE_API_BASE_URL=http://localhost:4190

# Google 3D Maps — enables the photorealistic block view on /explore.
# Both are optional; missing values trigger a styled fallback card.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_3D_MAP_ID=

# OpenAI — powers the "Render this view" button in /designer.
# The browser calls /v1/images/edits directly with the captured viewport
# PNG + a style prompt. This key ships in the bundle, so only enable it
# for local development demos. Defaults if unset: model=gpt-image-1,
# size=1024x1024.
VITE_OPENAI_API_KEY=
VITE_OPENAI_IMAGE_MODEL=gpt-image-1
VITE_OPENAI_IMAGE_SIZE=1024x1024
